{
  "$schema": "https://turbo.build/json-schema.json",
  "experimentalUI": true,
  "globalDependencies": ["**/.env", "**/.env.local"],
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "dev": {
      "cache": false
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": [],
      "cache": false
    },
    "type-check": {
      "outputs": []
    }
  }
}
