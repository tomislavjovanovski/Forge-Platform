{
  "name": "@forge/monitoring",
  "version": "1.0.0",
  "description": "Error tracking and monitoring service (Sentry, accessibility, error handling)",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sentry": {
      "types": "./dist/sentry/index.d.ts",
      "import": "./dist/sentry/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./accessibility": {
      "types": "./dist/accessibility/index.d.ts",
      "import": "./dist/accessibility/index.js"
    },
    "./errorBoundary": {
      "types": "./dist/errorBoundary.d.ts",
      "import": "./dist/errorBoundary.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@sentry/react": "^7.84.0",
    "@axe-core/react": "^4.8.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  }
}
