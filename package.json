{
  "name": "forge-platform",
  "version": "1.0.0",
  "description": "Frontend platform engineering monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo build --filter=!storybook",
    "build:all": "turbo build",
    "build:storybook": "turbo build --filter=storybook",
    "dev": "turbo dev",
    "dev:dashboard": "turbo dev --filter=@forge/dashboard",
    "dev:playground": "turbo dev --filter=@forge/playground",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:watch": "turbo test -- --watch",
    "test:coverage": "turbo test -- --coverage",
    "test:e2e": "turbo test:e2e",
    "preview:dashboard": "pnpm --dir ./apps/dashboard exec vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "preview:playground": "pnpm --dir ./apps/playground exec vite preview --host 127.0.0.1 --port 4174 --strictPort",
    "test:e2e:dashboard": "PW_APP=dashboard PW_PORT=4173 pnpm exec playwright test apps/dashboard/tests --reporter=html",
    "test:e2e:playground": "PW_APP=playground PW_PORT=4174 pnpm exec playwright test apps/playground/tests --reporter=html",
    "test:accessibility": "vitest run \"**/*.a11y.test.ts\"",
    "analyze:bundle": "pnpm exec vite build --config tooling/vite.analyze.config.ts --mode production",
    "lhci:collect": "lhci collect --config .lighthouserc.json",
    "lhci:assert": "lhci assert --config .lighthouserc.json",
    "semantic-release": "semantic-release",
    "clean": "turbo clean && rm -rf node_modules",
    "clean:dist": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "changeset publish",
    "deps:check": "turbo deps-check",
    "deps:visualize": "turbo graph",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^20.10.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.0.0",
    "jsdom": "^23.0.0",
    "vitest": "^1.0.0",
    "@lhci/cli": "^0.11.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.5.14",
    "prettier": "^3.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "semantic-release": "^21.0.0",
    "tailwindcss": "3",
    "turbo": "^1.10.16",
    "typescript": "5.3.3"
  },

  "overrides": {
    "typescript": "5.3.3"
  },
  "dependencies": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
  }
}
