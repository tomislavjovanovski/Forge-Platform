{
  "name": "forge-platform",
  "version": "1.0.0",
  "description": "Enterprise-grade SaaS frontend platform monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo build --filter=!storybook",
    "build:all": "turbo build",
    "build:storybook": "turbo build --filter=storybook",
    "dev": "turbo dev",
    "dev:admin": "turbo dev --filter=admin-dashboard",
    "dev:analytics": "turbo dev --filter=analytics-dashboard",
    "dev:portal": "turbo dev --filter=public-portal",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:watch": "turbo test -- --watch",
    "test:coverage": "turbo test -- --coverage",
    "test:e2e": "turbo test:e2e",
    "preview:admin": "pnpm --dir ./apps/admin-dashboard exec vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "preview:analytics": "pnpm --dir ./apps/analytics-dashboard exec vite preview --host 127.0.0.1 --port 4174 --strictPort",
    "preview:portal": "pnpm --dir ./apps/public-portal exec vite preview --host 127.0.0.1 --port 4175 --strictPort",
    "test:e2e:admin": "PW_APP=admin-dashboard PW_PORT=4173 pnpm exec playwright test apps/admin-dashboard/tests --reporter=html",
    "test:e2e:analytics": "PW_APP=analytics-dashboard PW_PORT=4174 pnpm exec playwright test apps/analytics-dashboard/tests --reporter=html",
    "test:e2e:portal": "PW_APP=public-portal PW_PORT=4175 pnpm exec playwright test apps/public-portal/tests --reporter=html",
    "test:accessibility": "pnpm exec vitest --run --include='**/*.a11y.test.ts'",
    "analyze:bundle": "pnpm exec vite build --config tooling/vite.analyze.config.ts --mode production",
    "lhci:collect": "lhci collect --config .lighthouserc.json",
    "lhci:assert": "lhci assert --config .lighthouserc.json",
    "semantic-release": "semantic-release",
    "clean": "turbo clean && rm -rf node_modules",
    "clean:dist": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "changeset publish",
    "deps:check": "turbo deps-check",
    "deps:visualize": "turbo graph",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^20.10.0",
    "@types/react": "18",
    "@types/react-dom": "18",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@lhci/cli": "^0.11.0",
    "@semantic-release/changelog": "^8.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^10.0.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.5.14",
    "prettier": "^3.1.0",
    "@rollup/plugin-visualizer": "^0.12.0",
    "semantic-release": "^21.0.0",
    "tailwindcss": "3",
    "turbo": "^1.10.16",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "react": "18",
    "react-dom": "18"
  }
}
